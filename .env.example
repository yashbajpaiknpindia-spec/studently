# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# PostgreSQL connection string (see prisma/schema.prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/studently"

# Secret used to sign admin session JWTs — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-random-64-char-hex-string"

# Admin login credentials (plain text).
ADMIN_PHONE="7897671348"
ADMIN_PASSWORD="replace-with-your-password"

# Anthropic API key — powers the AI Tools page (resume/SOP/cover letter/interview
# prep/career roadmap/scholarship match). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Razorpay (for the payments phase)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Google OAuth (student login/signup with Google) — from Google Cloud Console →
# APIs & Services → Credentials → OAuth client ID (type: Web application).
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below, e.g.
#   http://localhost:3000/api/auth/google/callback        (local dev)
#   https://your-app.onrender.com/api/auth/google/callback (production)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional — only needed if the server's request origin doesn't match your
# public URL (e.g. behind certain proxies). Usually leave unset; it's derived
# automatically from the incoming request otherwise.
GOOGLE_REDIRECT_URI=""

# --- Opportunity Aggregation Engine ---

# Shared secret protecting /api/cron/aggregate. Generate the same way as
# JWT_SECRET, then point your scheduler (Render Cron Jobs, GitHub Actions
# schedule, system crontab, etc.) at:
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" https://<your-app>/api/cron/aggregate
# Alternatively, run `npm run aggregate` (one-off) or `npm run worker`
# (long-running process) directly — see README for the tradeoffs.
CRON_SECRET=""

# Only needed if you enable the seeded "[Example] data.gov.in open dataset"
# Source (or add your own data.gov.in JSON_API source) — get a free key at
# https://data.gov.in/help/how-use-datasets-apis
DATA_GOV_IN_KEY=""

# How often the persistent worker (`npm run worker`) checks for due sources,
# in minutes. Each Source still only actually fetches at its own
# fetchIntervalMins — this just controls how often the worker wakes up to check.
WORKER_TICK_MINUTES="15"

